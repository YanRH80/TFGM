	author = {Mueller, Pam A and Oppenheimer, Daniel M},
	file = {PDF:/Users/yanrodriguez/Zotero/storage/RE3C8INA/Mueller y Oppenheimer - The Pen Is Mightier Than the Keyboard Advantages of Longhand Over Laptop Note Taking.pdf:application/pdf},
